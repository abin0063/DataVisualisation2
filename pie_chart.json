{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": { "text": "E-commerce Platforms (Average Monthly Site Visits)" },
    "data": {
        "url": "data/platform_marketplace.csv"
    },
    "mark": {"type":"arc",
    "outerRadius": 120},
    
    "encoding": {
        "theta": { "field": "Avg_monthly_marketplace", "type": "quantitative"},
        "color": { "field": "Platform", "type": "nominal", "title": "Platform"},
        "tooltip": [
            {
                "field": "Platform",
                "type": "nominal"
            },
            {
                "field": "Avg_monthly_marketplace",
                "type": "quantitative",
                "title": "Avg Monthly (millions)"
            }
        ]
    }, "view": {
        "stroke": null
    }
}